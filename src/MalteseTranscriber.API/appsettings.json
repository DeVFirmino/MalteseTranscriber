{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Speechmatics": {
    "Endpoint": "wss://eu.rt.speechmatics.com/v2",
    "DisconnectDelayMs": 2000,
    "MaxConcurrentSessions": 10
  },
  "Translation": {
    "Model": "gpt-4o",
    "MaxTokens": 300,
    "ContextWindowSize": 5,
    "BaseUrl": "https://api.openai.com/v1/chat/completions"
  },
  "Session": {
    "TtlHours": 2
  },
  "SignalR": {
    "MaximumReceiveMessageSizeBytes": 1048576
  }
}
